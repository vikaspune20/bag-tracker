generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  fullName         String
  email            String    @unique
  phone            String
  address          String
  state            String
  city             String
  zip              String?
  country          String    @default("United States")
  identificationNo String
  passwordHash     String
  profilePicUrl    String?
  role             String    @default("USER")
  resetToken       String?
  resetTokenExpiry DateTime?
  isPremium        Boolean   @default(false)
  planType         String?
  subscriptionId   String?
  expiryDate       DateTime?
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trips         Trip[]
  notifications Notification[]
  subscriptions Subscription[]
}

model Trip {
  id                 String    @id @default(uuid())
  userId             String
  flightNumber       String
  airlineName        String
  departureAirport   String
  destinationAirport String
  departureDateTime  DateTime
  arrivalDateTime    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id])
  bags Bag[]

  @@index([userId, departureDateTime])
}

model Bag {
  id          String   @id @default(uuid())
  tripId      String
  tagNumber   String          // ← removed @unique here
  description String
  imagePath   String?
  weightLbs   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip          Trip           @relation(fields: [tripId], references: [id])
  trackingLogs  TrackingLog[]
  notifications Notification[]

  @@unique([tripId, tagNumber])   // ← composite unique to match your table
  @@index([tripId, tagNumber])
}

model TrackingLog {
  id              String   @id @default(uuid())
  bagId           String
  status          String
  airportLocation String?
  remarks         String?
  timestamp       DateTime @default(now())

  bag Bag @relation(fields: [bagId], references: [id])

  @@index([bagId, timestamp])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  bagId     String?
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  bag  Bag? @relation(fields: [bagId], references: [id])

  @@index([userId, createdAt])
}

model Subscription {
  id                    String    @id @default(uuid())
  userId                String
  planMonths            Int
  amount                Int
  stripePaymentIntentId String    @unique
  status                String
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  currentPeriodEnd      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}
