generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  fullName         String
  email            String    @unique
  phone            String
  address          String
  state            String
  city             String
  zip              String?
  country          String    @default("United States")
  identificationNo String?
  passwordHash     String
  profilePicUrl    String?
  role             String    @default("USER")
  resetToken       String?
  resetTokenExpiry DateTime?
  emailVerified    Boolean   @default(false)
  emailOtp         String?
  emailOtpExpiry   DateTime?
  expiryReminder7SentAt DateTime?
  expiryReminder0SentAt DateTime?
  isPremium        Boolean   @default(false)
  planType         String?
  subscriptionId   String?
  expiryDate        DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  stripeCustomerId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trips         Trip[]
  notifications Notification[]
  subscriptions Subscription[]
  devices       TrackingDevice[]
  deviceOrders  DeviceOrder[]
}

model Trip {
  id                 String    @id @default(uuid())
  userId             String
  flightNumber       String
  airlineName        String
  departureAirport   String
  destinationAirport String
  departureDateTime  DateTime
  arrivalDateTime    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id])
  bags Bag[]

  @@index([userId, departureDateTime])
}

model Bag {
  id          String   @id @default(uuid())
  tripId      String
  tagNumber   String          // ← removed @unique here
  description String
  imagePath   String?
  weightLbs   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip          Trip           @relation(fields: [tripId], references: [id])
  trackingLogs  TrackingLog[]
  notifications Notification[]

  @@unique([tripId, tagNumber])   // ← composite unique to match your table
  @@index([tripId, tagNumber])
}

model TrackingLog {
  id              String   @id @default(uuid())
  bagId           String
  status          String
  airportLocation String?
  remarks         String?
  timestamp       DateTime @default(now())

  bag Bag @relation(fields: [bagId], references: [id])

  @@index([bagId, timestamp])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  bagId     String?
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  bag  Bag? @relation(fields: [bagId], references: [id])

  @@index([userId, createdAt])
}

model Subscription {
  id                    String    @id @default(uuid())
  userId                String
  deviceId              String?   // TrackingDevice.id this payment covers (null = legacy app-level)
  planMonths            Int
  amount                Int
  stripePaymentIntentId String    @unique
  status                String
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  currentPeriodEnd      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([deviceId])
}

model TrackingDevice {
  id          String   @id @default(uuid())
  userId      String
  orderId     String
  deviceId    String   @unique
  status      String   @default("ACTIVE")   // ACTIVE | EXPIRED (hardware)
  purchasedAt DateTime @default(now())
  expiresAt   DateTime                       // hardware expiry (1 year)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Per-device subscription ──────────────────
  subStatus            String   @default("NONE") // NONE | ACTIVE | EXPIRED
  subPlan              String?                    // MONTHLY_200 | QUARTERLY_400 | YEARLY_600 | DEVICE_BONUS
  subExpiry            DateTime?                  // when this device's subscription ends
  subStripeSubId       String?                    // reserved for future recurring
  subCancelAtPeriodEnd Boolean  @default(false)

  user  User        @relation(fields: [userId], references: [id])
  order DeviceOrder @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([userId, subStatus])
}

model DeviceOrder {
  id                    String    @id @default(uuid())
  userId                String
  productSku            String
  productName           String
  quantity              Int
  unitAmount            Int
  totalAmount           Int
  currency              String    @default("usd")
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?   @unique
  status                String    @default("PENDING")
  shippingName          String
  shippingPhone         String
  shippingAddressLine   String
  shippingCity          String
  shippingState         String
  shippingZip           String
  shippingCountry       String    @default("United States")
  bonusGranted          Boolean   @default(false)
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id])
  devices TrackingDevice[]

  @@index([userId, status])
}
